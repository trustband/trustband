# TrustBand environment template.
# Copy real values into ~/.config/secrets/api-keys.env (chmod 600), NOT into this repo.
# The offline pipeline (--bus memory --llm fake) needs none of these.

# Band platform (required only for --bus band)
BAND_API_KEY=

# LLM providers (required only for --llm real)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
